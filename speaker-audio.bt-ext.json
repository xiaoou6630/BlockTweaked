{
  "id": "speaker_audio",
  "name": "扬声器音频",
  "nameEn": "Speaker Audio",
  "colour": "#E91E63",
  "icon": "🔊",
  "description": "扬声器外设：播放音符、声音、DFPWM音频流",
  "descriptionEn": "Speaker peripheral: play notes, sounds, DFPWM audio streams",
  "blocks": [
    {
      "type": "speaker_playNote",
      "message0": "🔊 播放音符 %1 音量 %2 音高 %3",
      "args0": [
        { "type": "field_dropdown", "name": "INSTRUMENT", "options": [
          ["harp", "harp"], ["basedrum", "basedrum"], ["snare", "snare"],
          ["hat", "hat"], ["bass", "bass"], ["flute", "flute"],
          ["bell", "bell"], ["guitar", "guitar"], ["chime", "chime"],
          ["xylophone", "xylophone"], ["iron_xylophone", "iron_xylophone"],
          ["cow_bell", "cow_bell"], ["didgeridoo", "didgeridoo"],
          ["bit", "bit"], ["banjo", "banjo"], ["pling", "pling"]
        ]},
        { "type": "field_number", "name": "VOLUME", "value": 1, "min": 0, "max": 3, "precision": 0.1 },
        { "type": "field_number", "name": "PITCH", "value": 12, "min": 0, "max": 24, "precision": 1 }
      ],
      "previousStatement": null,
      "nextStatement": null,
      "colour": "#E91E63",
      "tooltip": "播放音符盒音符（每个tick最多8个）"
    },
    {
      "type": "speaker_playSound",
      "message0": "🔊 播放声音 %1 音量 %2 音高 %3",
      "args0": [
        { "type": "field_input", "name": "SOUND", "text": "minecraft:block.note_block.harp" },
        { "type": "field_number", "name": "VOLUME", "value": 1, "min": 0, "max": 3, "precision": 0.1 },
        { "type": "field_number", "name": "PITCH", "value": 1, "min": 0.5, "max": 2, "precision": 0.1 }
      ],
      "previousStatement": null,
      "nextStatement": null,
      "colour": "#E91E63",
      "tooltip": "播放Minecraft原版或模组声音"
    },
    {
      "type": "speaker_playAudio",
      "message0": "🔊 流式播放音频 %1 音量 %2",
      "args0": [
        { "type": "input_value", "name": "AUDIO", "check": null },
        { "type": "field_number", "name": "VOLUME", "value": 1, "min": 0, "max": 3, "precision": 0.1 }
      ],
      "previousStatement": null,
      "nextStatement": null,
      "colour": "#E91E63",
      "tooltip": "流式播放PCM音频数据（振幅-128~127），缓冲区满时返回false"
    },
    {
      "type": "speaker_stop",
      "message0": "🔇 停止扬声器",
      "previousStatement": null,
      "nextStatement": null,
      "colour": "#E91E63",
      "tooltip": "停止扬声器正在播放的所有音频"
    },
    {
      "type": "speaker_waitAudio",
      "message0": "⏳ 等待扬声器缓冲区空闲",
      "previousStatement": null,
      "nextStatement": null,
      "colour": "#E91E63",
      "tooltip": "等待speaker_audio_empty事件，直到缓冲区可接受新音频"
    },
    {
      "type": "dfpwm_encode",
      "message0": "🎵 DFPWM编码 %1",
      "args0": [
        { "type": "input_value", "name": "INPUT", "check": null }
      ],
      "output": "String",
      "colour": "#9C27B0",
      "tooltip": "将PCM振幅表编码为DFPWM字符串（一次性编码）"
    },
    {
      "type": "dfpwm_decode",
      "message0": "🎵 DFPWM解码 %1",
      "args0": [
        { "type": "input_value", "name": "INPUT", "check": "String" }
      ],
      "output": null,
      "colour": "#9C27B0",
      "tooltip": "将DFPWM字符串解码为PCM振幅表"
    },
    {
      "type": "dfpwm_make_encoder",
      "message0": "🎵 创建DFPWM编码器",
      "output": null,
      "colour": "#9C27B0",
      "tooltip": "创建流式DFPWM编码器函数（用于分块编码）"
    },
    {
      "type": "dfpwm_make_decoder",
      "message0": "🎵 创建DFPWM解码器",
      "output": null,
      "colour": "#9C27B0",
      "tooltip": "创建流式DFPWM解码器函数（用于分块解码）"
    }
  ],
  "generators": {
    "speaker_playNote": "speaker.playNote(\"${INSTRUMENT}\", ${VOLUME}, ${PITCH})",
    "speaker_playSound": "speaker.playSound(\"${SOUND}\", ${VOLUME}, ${PITCH})",
    "speaker_playAudio": "speaker.playAudio(${AUDIO}, ${VOLUME})",
    "speaker_stop": "speaker.stop()",
    "speaker_waitAudio": "os.pullEvent(\"speaker_audio_empty\")",
    "dfpwm_encode": "require('cc.audio.dfpwm').encode(${INPUT})",
    "dfpwm_decode": "require('cc.audio.dfpwm').decode(${INPUT})",
    "dfpwm_make_encoder": "require('cc.audio.dfpwm').make_encoder()",
    "dfpwm_make_decoder": "require('cc.audio.dfpwm').make_decoder()"
  }
}
